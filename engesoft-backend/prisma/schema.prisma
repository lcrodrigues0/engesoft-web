generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum BaseType {
  GUEST
  CONTRIBUTOR
}

enum Role {
  REVIEWER
  AUTHOR
  CHIEF_EDITOR
  SUBSCRIBER
}

model User {
  id            String      @id @default(uuid())
  name          String      @unique
  email         String      @unique
  password      String
  refreshToken  String?
  baseType      BaseType    @default(GUEST)
  roles         Role[]      @default([])
  createdAt     DateTime    @default(now())
}

